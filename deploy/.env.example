# Copy to deploy/.env (do not commit .env). Docker Compose reads variables from deploy/.env
# when you run compose from the repo root with -f deploy/docker-compose.dev.yml

# Keycloak dev admin password (login: admin). Confidential client secrets for rag-query / rag-ingest
# are generated at import — copy from Admin Console → Clients → Credentials (not stored in realm-export.json).
KEYCLOAK_ADMIN_PASSWORD=admin
